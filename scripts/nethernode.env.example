# Copy to scripts/nethernode.local.env. Values here are non-secret.
# Process environment wins over this file. Do not put key passphrases here.

# Optional. Leave empty to use normal AWS CLI credential selection.
AWS_PROFILE=
AWS_REGION=us-east-1
EC2_INSTANCE_ID=i-0123456789abcdef0

SSH_USER=ec2-user
SSH_KEY_PATH=/absolute/path/to/nethernode.pem
REMOTE_APP_DIR=/opt/nethernode/app
MINECRAFT_STATUS_HOST=example.minecraft.host

POLL_INTERVAL_SECONDS=10
SSH_CONNECT_TIMEOUT_SECONDS=10
