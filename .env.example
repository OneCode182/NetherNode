# Core compose/project settings
COMPOSE_PROJECT_NAME=nethernode
COMPOSE_FILE=compose.yaml
WORKDIR=.

# Local Minecraft runtime (local first, no secrets)
MINECRAFT_IMAGE=itzg/minecraft-server:stable-java25
MINECRAFT_DATA_DIR=./data/minecraft
MINECRAFT_EULA=FALSE
MINECRAFT_TYPE=FABRIC
MINECRAFT_VERSION=26.2
MINECRAFT_MEMORY=1536M
MINECRAFT_MAX_PLAYERS=5
MINECRAFT_DIFFICULTY=easy
MINECRAFT_VIEW_DISTANCE=8
MINECRAFT_SIMULATION_DISTANCE=6
MINECRAFT_LEVEL=normal
MINECRAFT_PORT=25565
MINECRAFT_BEDROCK_PORT=19132
MINECRAFT_BIND_ADDR=0.0.0.0
MINECRAFT_SERVER_NAME=NetherNode Local
MINECRAFT_MOTD=Local NetherNode Runtime
MINECRAFT_SEED=
MINECRAFT_JVM_OPTS=
MINECRAFT_ONLINE_MODE=false
MINECRAFT_ENABLE_RCON=true
MINECRAFT_RCON_PASSWORD=change-me-local-only
MINECRAFT_RCON_PORT=25575
MINECRAFT_MODRINTH_PROJECTS=
MINECRAFT_MODRINTH_ALLOWED_VERSION_TYPE=release

# Ops defaults (dry-run safe for automation)
BACKUP_SOURCE=./data/minecraft
BACKUP_DEST=./backups
BACKUP_RETENTION=7
BACKUP_LABEL=minecraft

# Optional dynamic DNS; never commit real token values
DUCKDNS_DOMAIN=
DUCKDNS_TOKEN=
